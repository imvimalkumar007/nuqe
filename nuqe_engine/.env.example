# Local Docker Postgres (default for development)
DATABASE_URL=postgresql://nuqe:nuqe_secret@localhost:5433/nuqe_engine

# Optional: separate DB URL for migrations (bypasses RLS).
# Falls back to DATABASE_URL if unset.
# MIGRATION_DATABASE_URL=postgresql://nuqe_admin:admin_secret@localhost:5433/nuqe_engine

# Library file location (optional — F3.2: libraries are now stored per-org in the DB).
# Only needed for the legacy POST /library/sync endpoint. Will be removed in F3.3.
# LIBRARY_PATH=./Nuqe_Obligation_Library.xlsx

# Audit log HMAC signing key. Generate one with: openssl rand -hex 32
AUDIT_SIGNING_KEY=replace-with-real-key-before-running

# Logging
LOG_LEVEL=INFO

# ── Auth (F3.3) ───────────────────────────────────────────────────────────────
#
# AUTH_MODE controls how the API authenticates requests.
#
# static (default):
#   Uses the static NUQE_API_TOKEN Bearer token + X-Org-Id header.
#   No Auth0 config needed. Safe for development and pre-Auth0 deployments.
#
# auth0:
#   Uses Auth0-issued RS256 JWTs. NUQE_API_TOKEN is not checked.
#   AUTH0_DOMAIN and AUTH0_AUDIENCE must be set.
#   org_id is resolved from the JWT org_id claim (not from X-Org-Id header).
#   See docs/f33_auth0_setup.md for the full setup runbook.
#
AUTH_MODE=static

# Static Bearer token. Required when AUTH_MODE=static.
# Generate with: openssl rand -hex 32
NUQE_API_TOKEN=replace-with-real-token

# Auth0 settings. Required when AUTH_MODE=auth0. Leave commented when AUTH_MODE=static.
# AUTH0_DOMAIN=your-tenant.eu.auth0.com
# AUTH0_AUDIENCE=https://api.nuqe.io
# AUTH0_ALGORITHMS=RS256
# AUTH0_JWKS_CACHE_TTL_SECONDS=3600
